<% content_for :title, @milestone.title %>

<div class="px-8 py-10 max-w-content mx-auto animate-fade-in">
  <%= link_to "← Back to timeline",
        relationship_path(@relationship),
        class: "text-small text-ink-400 hover:text-ink-700 transition-colors" %>

  <div class="mt-8 flex flex-col gap-8">
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-2">
        <span class="tag <%= milestone_type_bg(@milestone.milestone_type) %>">
          <%= @milestone.type_label %>
        </span>
        <span class="text-small text-ink-400">
          <%= format_date_long(@milestone.occurred_on) %>
        </span>
      </div>
      <h1 class="font-serif text-display text-ink-800 leading-tight">
        <%= @milestone.title %>
      </h1>
      <% if @milestone.emotional_tags.present? %>
        <div class="flex flex-wrap gap-1.5">
          <% @milestone.emotional_tags.compact.each do |tag| %>
            <span class="tag-warm"><%= tag %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @milestone.description.present? %>
      <div class="card p-7 flex flex-col gap-2">
        <span class="insight-label">Description</span>
        <p class="text-body text-ink-600 leading-relaxed"><%= @milestone.description %></p>
      </div>
    <% end %>

    <div class="grid grid-cols-2 gap-5">
      <% if @milestone.my_perspective.present? %>
        <div class="card-soft p-5 flex flex-col gap-2">
          <span class="insight-label">My perspective</span>
          <p class="text-small text-ink-600 leading-relaxed italic"><%= @milestone.my_perspective %></p>
        </div>
      <% end %>
      <% if @milestone.partner_perspective.present? %>
        <div class="card-soft p-5 flex flex-col gap-2">
          <span class="insight-label">Their perspective</span>
          <p class="text-small text-ink-600 leading-relaxed italic"><%= @milestone.partner_perspective %></p>
        </div>
      <% end %>
    </div>

    <% if @milestone.conflict? && @milestone.repair_notes.present? %>
      <div class="card p-6 flex flex-col gap-2 border-l-2 border-sage-200">
        <span class="insight-label text-sage-600">Repair notes</span>
        <p class="text-small text-ink-600 leading-relaxed"><%= @milestone.repair_notes %></p>
      </div>
    <% end %>

    <% if @relationship.active? %>
      <div class="flex items-center gap-3 pt-4 border-t border-warm-200">
        <%= link_to "Edit", edit_relationship_milestone_path(@relationship, @milestone), class: "btn-secondary" %>
        <%= button_to "Remove", relationship_milestone_path(@relationship, @milestone),
              method: :delete,
              class: "btn-ghost text-rose-400 hover:text-rose-600",
              data: { turbo_confirm: "Remove this milestone?" } %>
      </div>
    <% end %>
  </div>
</div>
