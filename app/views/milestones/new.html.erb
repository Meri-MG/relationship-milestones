<% content_for :title, "Add milestone" %>

<div class="modal-backdrop" data-controller="step-modal" id="milestone-modal">
  <div class="modal-panel"
       data-action="click@window->step-modal#closeOnBackdrop"
       data-step-modal-target="panel">

    <%# Header with steps %>
    <div class="px-7 pt-6 pb-0 flex flex-col gap-4">
      <div class="flex items-center justify-between">
        <h2 class="font-serif text-title text-ink-800">
          <span data-step-modal-target="heading">Choose a type</span>
        </h2>
        <%= link_to relationship_path(@relationship), class: "btn-icon" do %>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        <% end %>
      </div>

      <%# Step dots %>
      <div class="flex items-center gap-1.5" aria-label="Step progress">
        <div class="step-dot active" data-step-modal-target="dot" data-step="1"></div>
        <div class="step-dot"        data-step-modal-target="dot" data-step="2"></div>
        <div class="step-dot"        data-step-modal-target="dot" data-step="3"></div>
      </div>
    </div>

    <%= form_with model: [@relationship, @milestone],
          url: relationship_milestones_path(@relationship),
          multipart: true,
          data: { step_modal_target: "form", turbo: false } do |f| %>

      <%# ── Step 1: Type selection ─────────────────────── %>
      <div class="p-7 pt-5 flex flex-col gap-3" data-step-modal-target="step" data-step="1">
        <p class="text-small text-ink-400 mb-2">
          What kind of moment was this?
        </p>

        <% [
          ["first",      "First",            "First meeting, first trip, first fight. The beginnings."],
          ["funny",      "Funny threshold",  "The moment something became a running joke."],
          ["conflict",   "Conflict",         "A moment of tension, disagreement, or distance."],
          ["growth",     "Growth",           "Something shifted. You understood each other differently."],
          ["transition", "Transition",       "A move, a change, a life milestone crossed together."],
          ["custom",     "Custom",           "Something that doesn't fit a category."],
        ].each do |value, label, description| %>
          <label class="flex items-start gap-3 p-3.5 rounded border border-warm-200 cursor-pointer
                         has-[:checked]:border-sage-400 has-[:checked]:bg-sage-50 transition-all duration-150
                         hover:border-warm-300 hover:bg-warm-50 group">
            <%= f.radio_button :milestone_type, value,
                  class: "sr-only",
                  data: {
                    action: "change->step-modal#selectType",
                    step_modal_type_param: value
                  } %>
            <span class="mt-0.5 w-3.5 h-3.5 rounded-full border-2 border-warm-300 shrink-0
                         group-has-[:checked]:border-sage-400 group-has-[:checked]:bg-sage-400 transition-all duration-150"></span>
            <span class="flex flex-col gap-0.5">
              <span class="text-small font-medium text-ink-800"><%= label %></span>
              <span class="text-micro text-ink-400 leading-relaxed"><%= description %></span>
            </span>
          </label>
        <% end %>

        <div class="flex justify-end pt-2">
          <button type="button"
                  class="btn-primary"
                  data-action="click->step-modal#nextStep">
            Continue
          </button>
        </div>
      </div>

      <%# ── Step 2: Details ───────────────────────────── %>
      <div class="p-7 pt-5 flex flex-col gap-5 hidden" data-step-modal-target="step" data-step="2">

        <div class="form-group">
          <%= f.label :title, "Title", class: "label" %>
          <%= f.text_field :title,
                placeholder: "A short, honest name for this moment",
                class: "input",
                data: { step_modal_target: "titleInput" } %>
        </div>

        <div class="form-group">
          <%= f.label :occurred_on, "When did this happen?", class: "label" %>
          <%= f.date_field :occurred_on, class: "input", value: Date.today %>
        </div>

        <div class="form-group">
          <%= f.label :description, "Description", class: "label" %>
          <%= f.text_area :description,
                rows: 3,
                placeholder: "What happened? Keep it honest, not performative.",
                class: "textarea" %>
        </div>

        <div class="form-group">
          <%= f.label :photo, "Photo", class: "label" %>
          <span class="text-micro text-ink-400 -mt-1 mb-1">Optional — attach a photo to this moment.</span>
          <%= f.file_field :photo,
                accept: "image/*",
                class: "block w-full text-small text-ink-600 file:mr-3 file:py-1.5 file:px-3
                        file:rounded file:border file:border-warm-300 file:bg-warm-100
                        file:text-small file:text-ink-600 file:cursor-pointer
                        hover:file:bg-warm-200 transition-all" %>
        </div>

        <%# Emotional tags %>
        <div class="form-group">
          <span class="label">Emotional texture</span>
          <div class="flex flex-wrap gap-2">
            <% Milestone::EMOTIONAL_TAGS.each do |tag| %>
              <label class="cursor-pointer">
                <input type="checkbox"
                       name="milestone[emotional_tags][]"
                       value="<%= tag %>"
                       class="sr-only peer"
                       <%= @milestone.emotional_tags.include?(tag) ? "checked" : "" %>>
                <span class="tag tag-warm peer-checked:bg-sage-100 peer-checked:text-sage-700
                             peer-checked:border-sage-300 transition-colors duration-150 cursor-pointer">
                  <%= tag %>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Emotional intensity slider %>
        <div class="form-group">
          <div class="flex items-center justify-between mb-1.5">
            <span class="label mb-0">Intensity</span>
            <span class="text-micro text-ink-400"
                  data-step-modal-target="intensityLabel">Moderate</span>
          </div>
          <%= f.range_field :emotional_intensity,
                min: 1, max: 10, step: 1,
                value: 5,
                class: "emotion-slider",
                data: {
                  action: "input->step-modal#updateIntensity",
                  step_modal_target: "intensitySlider"
                } %>
          <div class="flex justify-between mt-1">
            <span class="text-micro text-ink-300">Gentle</span>
            <span class="text-micro text-ink-300">Intense</span>
          </div>
        </div>

        <div class="flex justify-between pt-2">
          <button type="button" class="btn-ghost" data-action="click->step-modal#prevStep">
            Back
          </button>
          <button type="button" class="btn-primary" data-action="click->step-modal#nextStep">
            Continue
          </button>
        </div>
      </div>

      <%# ── Step 3: Perspectives + submit ─────────────── %>
      <div class="p-7 pt-5 flex flex-col gap-5 hidden" data-step-modal-target="step" data-step="3">

        <div class="form-group">
          <span class="label">My perspective <span class="text-ink-300 font-normal">(optional)</span></span>
          <%= f.text_area :my_perspective,
                rows: 3,
                placeholder: "How did this feel from where I stood?",
                class: "textarea" %>
        </div>

        <% if @relationship.couple? %>
          <div class="form-group">
            <span class="label">Their perspective <span class="text-ink-300 font-normal">(optional)</span></span>
            <%= f.text_area :partner_perspective,
                  rows: 3,
                  placeholder: "How did they experience this?",
                  class: "textarea" %>
          </div>
        <% end %>

        <%# Repair notes (conflict only) %>
        <div class="form-group hidden" data-step-modal-target="repairSection">
          <div class="card-soft p-4 flex flex-col gap-3 border-l-2 border-sage-200">
            <span class="text-micro text-sage-600 uppercase tracking-widest">Repair notes</span>
            <%= f.text_area :repair_notes,
                  rows: 2,
                  placeholder: "What helped? What was said? How did you move through it?",
                  class: "textarea border-0 bg-transparent p-0 focus:ring-0" %>
          </div>
        </div>

        <div class="flex justify-between pt-2">
          <button type="button" class="btn-ghost" data-action="click->step-modal#prevStep">
            Back
          </button>
          <%= f.submit "Record this moment",
                class: "btn-primary" %>
        </div>

        <p class="text-micro text-ink-300 text-center">
          A moment of tension has been recorded. — or — A milestone has been added.
          <%# tone reminder for devs %>
        </p>
      </div>

    <% end %>
  </div>
</div>
