<% content_for :title, "Edit milestone" %>

<div class="modal-backdrop" id="edit-milestone-modal">
  <div class="modal-panel">

    <div class="px-7 pt-6 flex items-center justify-between">
      <h2 class="font-serif text-title text-ink-800">Edit milestone</h2>
      <%= link_to relationship_path(@relationship), class: "btn-icon" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
      <% end %>
    </div>

    <%= form_with model: [@relationship, @milestone], local: true do |f| %>
      <div class="p-7 pt-5 flex flex-col gap-5">

        <div class="form-group">
          <%= f.label :title, "Title", class: "label" %>
          <%= f.text_field :title, class: "input" %>
        </div>

        <div class="form-group">
          <%= f.label :occurred_on, "Date", class: "label" %>
          <%= f.date_field :occurred_on, class: "input" %>
        </div>

        <div class="form-group">
          <%= f.label :description, "Description", class: "label" %>
          <%= f.text_area :description, rows: 3, class: "textarea" %>
        </div>

        <div class="form-group">
          <%= f.label :my_perspective, "My perspective", class: "label" %>
          <%= f.text_area :my_perspective, rows: 2, class: "textarea" %>
        </div>

        <% if @relationship.couple? %>
          <div class="form-group">
            <%= f.label :partner_perspective, "Their perspective", class: "label" %>
            <%= f.text_area :partner_perspective, rows: 2, class: "textarea" %>
          </div>
        <% end %>

        <% if @milestone.conflict? %>
          <div class="form-group">
            <span class="label">Repair notes</span>
            <%= f.text_area :repair_notes, rows: 2, class: "textarea",
                  placeholder: "What helped move through this?" %>
          </div>
        <% end %>

        <div class="flex justify-between pt-2">
          <%= link_to "Cancel", relationship_path(@relationship), class: "btn-ghost" %>
          <%= f.submit "Save changes", class: "btn-primary" %>
        </div>
      </div>
    <% end %>

  </div>
</div>
