<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title><%= content_for(:title).presence || "Relationship Milestones" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="manifest" href="/manifest.json">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="h-full bg-warm-50 antialiased">

  <%# ─── Sidebar Navigation ─────────────────────────────────── %>
  <% unless content_for?(:full_page) %>
    <aside class="sidebar hidden md:flex" aria-label="Primary navigation">
      <%# Avatar + relationship identity %>
      <div class="px-5 mb-8">
        <%= link_to root_path, class: "flex items-center gap-3 group" do %>
          <% if @relationship %>
            <div class="w-9 h-9 rounded-full bg-warm-300 flex items-center justify-center shrink-0">
              <span class="text-micro font-medium text-ink-700 uppercase tracking-wide">
                <%= person_name(@relationship)&.first(2) || "?" %>
              </span>
            </div>
            <div class="flex flex-col gap-0.5 min-w-0">
              <span class="font-serif text-small text-ink-800 leading-tight truncate">
                <%= @relationship.title %>
              </span>
              <span class="text-micro <%= @relationship.couple? ? 'text-sage-600' : 'text-ink-400' %>">
                <%= @relationship.couple? ? "Couple mode" : "Solo mode" %>
              </span>
            </div>
          <% else %>
            <div class="flex flex-col gap-0.5">
              <span class="font-serif text-title text-ink-800 leading-tight">Milestones</span>
              <span class="text-micro text-ink-400 tracking-wide">your story, preserved</span>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Primary nav %>
      <nav class="flex-1 px-3 flex flex-col gap-0.5">
        <%= link_to dashboard_path, class: "nav-link #{current_page?(dashboard_path) ? 'active' : ''}" do %>
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" class="nav-icon shrink-0">
            <rect x="1" y="1" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
            <rect x="8.5" y="1" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
            <rect x="1" y="8.5" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
            <rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
          </svg>
          Dashboard
        <% end %>

        <% if @relationship %>
          <%= link_to relationship_path(@relationship), class: "nav-link #{controller_name == 'relationships' ? 'active' : ''}" do %>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" class="nav-icon shrink-0">
              <path d="M2.5 4h10M2.5 7.5h10M2.5 11h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            Timeline
          <% end %>

          <%= link_to relationship_insights_path(@relationship), class: "nav-link #{controller_name == 'insights' ? 'active' : ''}" do %>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" class="nav-icon shrink-0">
              <path d="M2 11l3-4 3 2.5L10.5 5 13 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Insights
          <% end %>

          <%= link_to relationship_reflections_path(@relationship), class: "nav-link #{controller_name == 'reflections' ? 'active' : ''}" do %>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" class="nav-icon shrink-0">
              <path d="M2 3.5h11M2 6.5h8M2 9.5h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            Reflections
          <% end %>
        <% end %>
      </nav>

      <%# Bottom area — privacy badge + settings %>
      <div class="px-4 flex flex-col gap-3">
        <div class="privacy-badge">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 1L9 3V5.5C9 7.43 7.21 9.17 5 9.5C2.79 9.17 1 7.43 1 5.5V3L5 1Z" fill="currentColor" opacity="0.6"/>
          </svg>
          Private &amp; local
        </div>
        <%= link_to "#", class: "nav-link text-ink-400" do %>
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" class="nav-icon shrink-0">
            <circle cx="7.5" cy="7.5" r="2" stroke="currentColor" stroke-width="1.2"/>
            <path d="M7.5 1v1.5M7.5 12.5V14M1 7.5h1.5M12.5 7.5H14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          Settings
        <% end %>
      </div>
    </aside>

    <%# ─── Main Content ────────────────────────────────────────── %>
    <main class="main-content pb-20 md:pb-0">
      <%# Flash messages %>
      <% if notice %>
        <div class="fixed top-5 right-5 z-50 animate-slide-up">
          <div class="card px-5 py-3.5 flex items-center gap-3 max-w-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-sage-400 shrink-0"></span>
            <p class="text-small text-ink-700"><%= notice %></p>
            <button onclick="this.parentElement.parentElement.remove()"
                    class="ml-auto text-ink-300 hover:text-ink-600 transition-colors">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="fixed top-5 right-5 z-50 animate-slide-up">
          <div class="card px-5 py-3.5 flex items-center gap-3 max-w-sm border-rose-200">
            <span class="w-1.5 h-1.5 rounded-full bg-rose-400 shrink-0"></span>
            <p class="text-small text-ink-700"><%= alert %></p>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%# ─── Mobile Bottom Nav ──────────────────────────────────── %>
    <% if @relationship %>
      <nav class="bottom-nav md:hidden" aria-label="Mobile navigation">
        <%= link_to dashboard_path, class: "bottom-nav-item #{current_page?(dashboard_path) ? 'active' : ''}" do %>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="2" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <rect x="11" y="2" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <rect x="2" y="11" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <rect x="11" y="11" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.4"/>
          </svg>
          <span>Home</span>
        <% end %>
        <%= link_to relationship_path(@relationship), class: "bottom-nav-item #{controller_name == 'relationships' ? 'active' : ''}" do %>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 5.5h14M3 10h14M3 14.5h9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span>Timeline</span>
        <% end %>
        <%= link_to relationship_insights_path(@relationship), class: "bottom-nav-item #{controller_name == 'insights' ? 'active' : ''}" do %>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 14l4-5 4 3.5 4.5-7L18 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Insights</span>
        <% end %>
        <%= link_to relationship_reflections_path(@relationship), class: "bottom-nav-item #{controller_name == 'reflections' ? 'active' : ''}" do %>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 5h14M3 9h10M3 13h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span>Reflections</span>
        <% end %>
      </nav>
    <% end %>

  <% else %>
    <%# Full-page layout (landing, auth, ending screens) %>
    <%= yield %>
  <% end %>

</body>
</html>
